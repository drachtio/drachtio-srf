{
  "name": "drachtio-srf",
  "version": "5.0.20",
  "description": "drachtio signaling resource framework",
  "main": "lib/srf.js",
  "types": "lib/srf.d.ts",
  "exports": {
    ".": {
      "types": "./lib/srf.d.ts",
      "default": "./lib/srf.js"
    },
    "./lib/*": {
      "types": "./lib/*.d.ts",
      "default": "./lib/*.js"
    },
    "./*": {
      "types": "./lib/*.d.ts",
      "default": "./lib/*.js"
    }
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc",
    "test": "npm run build && NODE_ENV=test node test/ ",
    "coverage": "./node_modules/.bin/nyc --reporter html --report-dir ./coverage npm run test",
    "unittests": "npm run build && bunx tsc -p test/tsconfig.json && bunx mocha ./test-dist/test/unit-tests/*.js",
    "lint": "eslint src"
  },
  "engines": {
    "node": ">= 18.x"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drachtio/drachtio-srf.git"
  },
  "author": "Dave Horton",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/drachtio/drachtio-srf/issues"
  },
  "homepage": "https://github.com/drachtio/drachtio-srf#readme",
  "dependencies": {
    "debug": "^4.4.3",
    "delegates": "^1.0.0",
    "node-noop": "^1.0.0",
    "only": "^0.0.2",
    "sdp-transform": "^2.15.0",
    "short-uuid": "^5.2.0",
    "sip-methods": "^0.3.0",
    "sip-status": "^0.1.0",
    "utils-merge": "^1.0.1",
    "uuid-random": "^1.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@stylistic/eslint-plugin": "^5.5.0",
    "@types/debug": "^4.1.13",
    "@types/jscodeshift": "^17.3.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.18.12",
    "@types/sdp-transform": "^2.15.0",
    "config": "^4.1.1",
    "eslint": "^9.38.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^16.4.0",
    "jscodeshift": "^17.3.0",
    "mocha": "^11.7.4",
    "nyc": "^17.1.0",
    "should": "^13.2.3",
    "sip-message-examples": "^0.0.7",
    "tape": "^5.9.0",
    "typescript": "^5.9.3"
  }
}
